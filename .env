# Runtime Environment (dev, prod)
RUNTIME_ENV=prod
RUNTIME_TARGET=

# -----------------------
# APP 설정
# -----------------------
APP__PORT=28101
APP__USE_SSL=false
APP__USE_MANAGEMENT=true
APP__SITE_KEY=

# ms 설정
APP__SERVICE_NAME=kdb-manager-dev
APP__GROUP_NAME=
APP__EUREKA_SERVER=
APP__HOST_ID=1
APP__HOST_IP=

# -----------------------
# LOGGING 설정
# -----------------------
LOG__LEVEL=INFO
LOG__FORMAT=plain
LOG__OUTPUT_TARGET=both
LOG__DIR=./logs
LOG__FILE_MAX_BYTES=10485760
LOG__FILE_BACKUP_COUNT=5
LOG__FILENAME=app.log

# -----------------------
# REDIS 설정
# -----------------------
REDIS__HOST=10.30.1.196
REDIS__PORT=6379
REDIS__DB=0
REDIS__USERNAME=
REDIS__PASSWORD=
REDIS__SSL=false

# -----------------------
# DB 설정
# -----------------------
DB__PROVIDER=mongo
DB__HOST=10.30.1.205
DB__PORT=27017
DB__USERNAME=
DB__PASSWORD=
DB__AUTH_SOURCE=

# -----------------------
# MQ 설정
# -----------------------
MQ__PROVIDER=rabbitmq
MQ__HOST=10.30.1.196
MQ__PORT=5672
MQ__USERNAME=
MQ__PASSWORD=
MQ__VIRTUAL_HOST=/
MQ__SSL=false
MQ__HEARTBEAT=600

# -----------------------
# 모델 설정
# -----------------------
MODEL__DENSE_NAME="Qwen/Qwen3-Embedding-4B"
MODEL__DENSE_PATH="./models"
MODEL__SPARSE_NAME="Qdrant/bm42-all-minilm-l6-v2-attentions"
MODEL__SPARSE_PATH="./models"
# kdb-manager에서는 Reranker 까지 지원예정이었으나 리소스 문제로 reranker는 별도의 마이크로서비스로 분리하여 운영
MODEL__RERANK_PATH="./models"
MODEL__MODEL_DEVICE="cuda"

# -----------------------
# QDRANT 설정
# -----------------------
QDRANT__URL="http://127.0.0.1:6333"
QDRANT__API_KEY=""

# -----------------------
# RERANKER 설정
# -----------------------
MS__RERANKER="http://127.0.0.1:18080/api/reranker_ms"

